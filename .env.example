# NetRunner Pro v4.0 - Variables de Entorno

# === API DE IA (al menos una requerida) ===
GROQ_API_KEY=gsk_tu_api_key_aqui
OPENCODE_ZEN_API_KEY=tu_api_key_aqui

# === PUERTO (Railway lo asigna automáticamente) ===
PORT=3000

# === ENTORNO ===
NODE_ENV=production

# === BACKBLAZE B2 CONFIG ===
B2_ENDPOINT=https://s3.us-east-005.backblazeb2.com
B2_BUCKET_NAME=tu_bucket_name
B2_ACCESS_KEY_ID=tu_key_id
B2_SECRET_ACCESS_KEY=tu_secret_key

# === AGENTE B2 KEYS ===
# Ruta del ejecutable Windows en B2 (ej: agents/windows/netrunner_agent.exe)
AGENT_WIN_KEY=agents/windows/netrunner_agent.exe
# Ruta del ejecutable Linux en B2 (ej: agents/linux/netrunner_agent)
AGENT_LINX_KEY=agents/linux/netrunner_agent
